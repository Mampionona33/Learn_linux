navigation        : pwd        				: Affiche le chemin absolu du répertoire courant
utilisateur       : whoami     				: Affiche le nom de l’utilisateur courant

gestion_fichiers : ls        				: Liste détaillée récursive (-a tous, -l détail, -h taille humaine, -t tri date, -S tri taille, -R récursif, -d dossier seul)
gestion_fichiers : cp        				: Copie fichier → dossier (-r récursif, -i confirmation, -v verbose, -u si plus récent)
gestion_fichiers : rm        				: Supprime dossier + contenu (-r récursif, -f force, -i confirmation, -v verbose)
gestion_fichiers : mv        				: Renomme/déplace fichier (-i confirmation, -v verbose, -n ne pas écraser)
gestion_fichiers : mkdir     				: Crée arborescence (-p parents, -v verbose, -m permissions)
gestion_fichiers : chmod     				: Change permissions (u+x ajoute exécution, -x enlève, 755 mode octal, -R récursif)
gestion_fichiers : chown     				: Change propriétaire+groupe (user:group, -R récursif, --reference=cible)
gestion_fichiers : chgrp     				: Change groupe propriétaire (-R récursif, --reference=cible)
gestion_fichiers : truncate  				: Modifie taille fichier (-s taille cible, -c ne pas créer si absent)
gestion_fichiers : split     				: Découpe fichier en morceaux (split -b 1M fichier prefix → fichiers de 1 Mo ; split -l 1000 fichier prefix → fichiers de 1000 lignes)

recherche        : find      				: Recherche fichiers/dossiers (-name nom, -iname ignore casse, -type f/d, -mtime -7 <7j, -size +1M >1Mo, -exec cmd {} \;)

wildcards        : *         				: Tous caractères (0+). Ex: *.txt
wildcards        : ?         				: Exactement 1 caractère. Ex: photo?.jpg
wildcards        : []        				: Un caractère parmi liste/plage. Ex: file[1-3].log
wildcards        : {}        				: Expansion motifs. Ex: *.{jpg,png}
wildcards        : {n..m}    				: Séquence numérique/alphabetique. Ex: file{1..3}.log

gestion_erreurs  : 2>/dev/null i			: Ignore erreurs (redirige vers néant)

comparaison      : diff     				: Compare ligne par ligne (-r récursif, -i ignore casse, -w ignore espaces, -q juste différent, -y côte à côte)
comparaison      : cmp      				: Compare octet par octet (-l octets différents, -s silencieux, -n limite octets)

traitement_texte : cut       				: Extrait colonne (-d délimiteur, -f champs, -c caractères, -b octets ; ex: cut -d ":" -f1 /etc/passwd → affiche logins)
traitement_texte : awk      				: Affiche colonne (-F délimiteur, -v variable, {action} script)
traitement_texte : grep     				: Recherche texte (-i ignore casse, -v inverse, -r récursif, -n num ligne, -c compte, -o match seul, -E regex étendue)
traitement_texte : sort     				: Tri (-n numérique, -r inverse, -k clé, -t délimiteur, -u unique, -h tailles humaines)
traitement_texte : uniq     				: Supprime doublons (-c compte, -d doublons, -u uniques, -i ignore casse)
traitement_texte : wc       				: Compte (-l lignes, -w mots, -c octets, -m caractères unicode)
traitement_texte : sed s/old/new/g			: Remplace texte (-i modifie fichier, -E regex étendue)
traitement_texte : sed 3d    				: Supprime ligne 3 (variante /erreur/d supprime lignes contenant "erreur")
traitement_texte : sed -n '1,5p' 			: Affiche lignes 1 à 5 (-n silencieux, p print)
traitement_texte : sed -E 's/^[0-9]+/X/' 	: Regex → remplace chiffres début ligne par X

affichage        : cat       				: Affiche fichier OU recolle morceaux (cat part_* > fichier_reconstruit)
affichage        : cat       				: Affiche fichier (-n num lignes, -b num lignes non vides, -s compresse vides, -E fin $, -T tabulations)
affichage        : less      				: Navigation page par page (-N num lignes, -S pas couper, -R couleurs, +F suivi)
affichage        : tail -f   				: Suit fichier en temps réel (-f suivi, -F suivi robuste, -n nb lignes, -q quiet)

edition          : vi        				: Édition texte (i insertion, :w sauvegarde, :q quitter, :set nu num lignes)
edition          : >         				: Redirection sortie → fichier (écrase contenu)
edition          : >>        				: Append sortie → fichier (ajoute à la suite)
edition          : tee       				: Écrit fichier + affiche (-a append, -i ignore interruptions)

compression      : tar       				: Archive fichiers/dossiers (tar -cvf archive.tar fichiers ; -xvf extrait ; -tvf liste contenu)
compression      : gzip      				: Compression fichier unique (gzip fichier → fichier.gz ; gunzip fichier.gz pour décompresser)
compression      : bzip2     				: Compression plus efficace que gzip (bzip2 fichier → fichier.bz2 ; bunzip2 fichier.bz2)
compression      : xz        				: Compression haute efficacité (xz fichier → fichier.xz ; unxz fichier.xz)
compression      : zip       				: Archive + compression (zip archive.zip fichiers ; unzip archive.zip pour extraire)
compression      : dzip      				: Compression rapide/différente selon implémentation (rare, souvent remplacé par gzip/bzip2/zip)

aide             : whatis ls 				: Description en une ligne (-r regex, -w wildcard)
aide             : --help    				: Résumé options
aide             : man ls    				: Manuel complet (Espace suivant, b précédent, /motif chercher, q quitter)

utilisateur      : useradd               	: Crée utilisateur (bas niveau ; ex: useradd -m bob → crée bob + home)
utilisateur      : adduser               	: Crée utilisateur (haut niveau ; ex: adduser alice → questions + home auto)
utilisateur      : passwd                	: Change mot de passe (ex: passwd bob → saisie nouveau mot de passe)
utilisateur      : id username           	: Affiche UID/GID/groupes (ex: id bob → uid=1001 gid=1001 groupes=bob,sudo)
utilisateur      : userdel -r            	: Supprime utilisateur + home (ex: userdel -r bob → supprime compte + /home/bob)
utilisateur      : usermod -G groupe     	: Remplace groupes (ex: usermod -G sudo bob → bob uniquement dans sudo)
utilisateur 	 : deluser bob              : Supprime utilisateur (home conservé par défaut)
utilisateur  	 : deluser --remove-home bob: Supprime utilisateur + home
utilisateur 	 : deluser --remove-all-files bob : Supprime utilisateur + tous ses fichiers

groupe      	 : deluser --group dev      : Supprime groupe “dev” (si vide)
groupe      	 : deluser bob sudo         : Retire bob du groupe sudo
groupe           : groupadd              	: Crée groupe (ex: groupadd dev → ajoute groupe “dev”)
groupe           : chgrp -R              	: Change groupe propriétaire (ex: chgrp -R dev /var/www)

liens             : ln                    	: Crée lien solide (hard link ; ex: ln fichier.txt copie.txt → même inode)
liens             : ln -s                 	: Crée lien symbolique (soft link ; ex: ln -s /usr/bin/python3 py → raccourci)

systeme          : /etc/passwd           	: Comptes utilisateurs (ex: bob:x:1001:1001:/home/bob:/bin/bash)
systeme          : /etc/group            	: Groupes (ex: dev:x:1002:bob,alice)
systeme          : /etc/shadow           	: Mots de passe chiffrés (ex: bob:$6$hash$...:19000:0:99999:7:::)

disque           : lsblk                	: Liste périphériques/partitions (ex: lsblk -f → avec UUID et FS)
disque           : fdisk                	: Partitionne disque MBR (ex: sudo fdisk /dev/sda → menu interactif)
disque           : parted               	: Partitionne disque GPT (ex: sudo parted /dev/sda → commandes modernes)
disque           : mkfs                 	: Formate partition (ex: sudo mkfs.ext4 /dev/sda1 → ext4)
disque           : mount                	: Monte partition (ex: sudo mount /dev/sda1 /mnt/disk1)
disque           : umount               	: Démonte partition (ex: sudo umount /mnt/disk1)
disque           : df                   	: Affiche espace disque (ex: df -h → taille humaine)
disque           : du                   	: Taille dossiers/fichiers (ex: du -sh /var/log → taille totale logs)
disque           : fsck                 	: Vérifie/répare FS (ex: sudo fsck /dev/sda1 → check ext4)
disque           : smartctl             	: Santé disque (ex: sudo smartctl -a /dev/sda → infos SMART)

